{
  "name": "delivery-scheduler",
  "version": "1.0.0",
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "dev": "concurrently \"node server/index.js\" \"cd client && npm run dev\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "pg": "^8.11.5",
    "nodemailer": "^6.9.13",
    "resend": "^3.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
